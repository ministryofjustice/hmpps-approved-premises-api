    {{#ApprovedPremises}}
    <h2>Approved Premises</h2>

        <h3>Applications</h3>
        {{#Applications}}
            <h4>Application</h4>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Application id</td>
                    <td class="data-column-25">Offence id</td>
                    <td class="data-column-25">Application user</td>
                    <td class="data-column-25">Sentence type</td>
                </tr>
                <tr>
                    <td>{{ optionalValue id }}</td>
                    <td>{{ optionalValue offence_id }}</td>
                    <td>{{ getUserLastName application_user_name }}</td>
                    <td>{{ convertCamelCase sentence_type }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Submitted at</td>
                    <td class="data-column-25">Withdrawal reason</td>
                    <td class="data-column-25">Application type</td>
                    <td class="data-column-25">Created at</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate submitted_at) }}</td>
                    <td>{{ optionalValue withdrawal_reason }}</td>
                    <td>{{ optionalValue ap_type }}</td>
                    <td>{{ optionalValue (formatDate created_at) }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Is withdrawn</td>
                    <td class="data-column-25">Inmate in out status on submission</td>
                    <td class="data-column-25">Created by</td>
                    <td class="data-column-25">Notice type</td>
                </tr>
                <tr>
                    <td>{{ convertBoolean is_withdrawn }}</td>
                    <td>{{ optionalValue inmate_in_out_status_on_submission }}</td>
                    <td>{{ getUserLastName created_by_user }}</td>
                    <td>{{ optionalValue notice_type }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Arrival date</td>
                    <td class="data-column-25">Target location</td>
                    <td class="data-column-25">Conviction id</td>
                    <td class="data-column-25">Case manager name</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate arrival_date) }}</td>
                    <td>{{ optionalValue target_location }}</td>
                    <td>{{ optionalValue conviction_id }}</td>
                    <td>{{ optionalValue case_manager_name }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Is emergency application</td>
                    <td class="data-column-25">Release type</td>
                    <td class="data-column-25">Name</td>
                    <td class="data-column-25">Case manager is not applicant</td>
                </tr>
                <tr>
                    <td>{{ convertBoolean is_emergency_application }}</td>
                    <td>{{ optionalValue release_type }}</td>
                    <td>{{ optionalValue name }}</td>
                    <td>{{ convertBoolean case_manager_is_not_applicant }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Event number</td>
                    <td class="data-column-25">Is women application</td>
                    <td class="data-column-25">Other withdrawal reason</td>
                    <td class="data-column-25">Status</td>
                </tr>
                <tr>
                    <td>{{ optionalValue event_number }}</td>
                    <td>{{ convertBoolean is_womens_application }}</td>
                    <td>{{ optionalValue other_withdrawal_reason }}</td>
                    <td>{{ optionalValue status }}</td>
                </tr>
            </table>
            <table class="data-table">
                <tr>
                    <td class="data-column-25">Type of approved premises</td>
                    <td class="data-column-25">Check your answers reviewed</td>
                </tr>
                <tr>
                    <td>{{ optionalValue data.type-of-ap.ap-type.type }}</td>
                    <td>{{ convertBoolean data.check-your-answers.review.reviewed }}</td>
                </tr>
            </table>

            <h5>Risk Ratings</h5>
            {{#risk_ratings}}
                <table class="data-table">
                    <tr>
                        <td class="data-column-50">Multi-Agency Public Protection Arrangements value</td>
                        <td class="data-column-50">Multi-Agency Public Protection Arrangements status</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue mappa.value }}</td>
                        <td>{{ optionalValue mappa.status }}</td>
                    </tr>
                </table>
                <table class="data-table">
                    <tr>
                        <td class="data-column-25">Tier level</td>
                        <td class="data-column-25">Tier status</td>
                        <td class="data-column-25">Tier last updated</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue tier.value.level }}</td>
                        <td>{{ optionalValue tier.status }}</td>
                        <td>{{ buildDateNumber tier.value.lastUpdated.[0] tier.value.lastUpdated.[1] tier.value.lastUpdated.[2] }}</td>
                    </tr>
                </table>
                <table class="data-table">
                    <tr>
                        <td class="data-column-25">Risk of Serious Harm overall risk</td>
                        <td class="data-column-25">Risk to Children</td>
                        <td class="data-column-25">Risk to Public</td>
                        <td class="data-column-25">Risk to Known Adult</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue roshRisks.value.overallRisk }}</td>
                        <td>{{ optionalValue roshRisks.value.riskToChildren }}</td>
                        <td>{{ optionalValue roshRisks.value.riskToPublic }}</td>
                        <td>{{ optionalValue roshRisks.value.riskToKnownAdult }}</td>
                    </tr>
                </table>
                <table class="data-table">
                    <tr>
                        <td class="data-column-25">Risk to Staff</td>
                        <td class="data-column-25">Risk of Serious Harm status</td>
                        <td class="data-column-25">Risk of Serious Harm last updated</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue roshRisks.value.riskToStaff }}</td>
                        <td>{{ optionalValue roshRisks.status }}</td>
                        <td>{{ buildDateNumber roshRisks.value.lastUpdated.[0] roshRisks.value.lastUpdated.[1] roshRisks.value.lastUpdated.[2] }}</td>
                    </tr>
                </table>
                <table class="data-table">
                    <tr>
                        <td class="data-column-50">Flags</td>
                        <td class="data-column-50">Flags status</td>
                    </tr>
                    <tr>
                        <td>{{#flags.value}}{{.}}{{#unless @last}}, {{/unless}}{{/flags.value}}{{^flags.value}}No Data Held{{/flags.value}}</td>
                        <td>{{ optionalValue flags.status }}</td>
                    </tr>
                </table>
            {{/risk_ratings}}
            {{^risk_ratings}}
                <p>No Data Held</p>
            {{/risk_ratings}}

            {{^document}}
                <h5>Unsubmitted Document</h5>
                {{#data}}
                    <p>The following is draft data captured for an unsubmitted form. Once submitted it will be presented in structured form with clear data labelling</p>
                    <table class="summary-list">
                        {{#each .}}
                            <tr><td class="data-column-50">{{ @key }}</td><td class="data-column-50">{{ this }}</td></tr>
                        {{/each}}
                    </table>
                {{/data}}
                {{^data}}
                    <p>No Data Held</p>
                {{/data}}
            {{/document}}

            <h5>Document</h5>
            {{#document}}
                <p><b>Offender Assessment System Import</b></p>
                {{#oasys-import}}
                    <table class="summary-list">{{#each .}}<tr><td>{{ @key }}</td><td>{{ optionalValue this }}</td></tr>{{/each}}</table><br/>
                {{/oasys-import}}
                {{^oasys-import}}
                    <p>No Data Held</p>
                {{/oasys-import}}

                <p><b>Risk Management Features</b></p>
                {{#risk-management-features}}
                    <table class="summary-list">{{#each .}}<tr><td class="data-column-50">{{ @key }}</td><td class="data-column-50">{{ optionalValue this }}</td></tr>{{/each}}</table><br/>
                {{/risk-management-features}}
                {{^risk-management-features}}
