                        <td class="data-column-25">Premises address line 2</td>
                    </tr>
                    <tr>
                        <td>{{ getUserLastName data.eventDetails.recordedBy.username }}</td>
                        <td>{{ optionalValue data.eventDetails.recordedBy.probationRegionCode }}</td>
                        <td>{{ optionalValue data.eventDetails.premises.addressLine1 }}</td>
                        <td>{{ optionalValue data.eventDetails.premises.addressLine2 }}</td>
                    </tr>
                </table>
                <table class="data-table">
                    <tr>
                        <td class="data-column-25">Premises town</td>
                        <td class="data-column-25">Premises region</td>
                        <td class="data-column-25">Premises postcode</td>
                        <td class="data-column-25">Departed at</td>
                    </tr>
                    <tr>
                        <td>{{ optionalValue data.eventDetails.premises.town }}</td>
                        <td>{{ optionalValue data.eventDetails.premises.region }}</td>
                        <td>{{ optionalValue data.eventDetails.premises.postcode }}</td>
                        <td>{{ optionalValue (formatDate data.eventDetails.departedAt) }}</td>
                    </tr>
                </table>
                <table class="summary-list">
                    <tr><td>Notes</td><td>{{ optionalValue data.eventDetails.notes }}</td></tr>
                </table>
            {{/if}}

            {{#if (eq type "CAS3_REFERRAL_SUBMITTED")}}
                <h4>Referral Submitted</h4>
            {{/if}}

            <table class="data-table">
                <tr>
                    <td class="data-column-25">Created at</td>
                    <td class="data-column-25">Trigger source</td>
                    <td class="data-column-25">Triggered by user</td>
                    <td class="data-column-25">Occurred at</td>
                </tr>
                <tr>
                    <td>{{ optionalValue (formatDate created_at) }}</td>
                    <td>{{ optionalValue trigger_source }}</td>
                    <td>{{ getUserLastName triggered_by_user }}</td>
                    <td>{{ optionalValue (formatDate occurred_at) }}</td>
                </tr>
            </table>

        {{/DomainEvents}}
        {{^DomainEvents}}
            <p>No Data Held</p>
        {{/DomainEvents}}

    {{/TemporaryAccommodation}}

{{/.}}
{{^.}}
    <p>No Data Held</p>
{{/.}}
