{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>ministryofjustice/hmpps-renovate-config:jvm"],
  "ignoreDeps": ["postgres", "postgis", "redis"],
  "packageRules": [
    {
      "description": "Ignore openapi version that breaks our swagger (see build.kts)",
      "matchPackageNames": [
        "org.springdoc:springdoc-openapi-starter-webmvc-ui",
        "org.springdoc:springdoc-openapi-starter-common"
      ],
      "allowedVersions": "!/3.0.3/"
    },
    {
      "matchManagers": ["github-actions"],
      "matchFileNames": ["**/.github/workflows/**/*.ya?ml"],
      "matchUpdateTypes": ["minor", "patch"],
      "enabled": false
    }
  ],
  "platformCommit": "enabled",
  "dependencyDashboard": true
}
